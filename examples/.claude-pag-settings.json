{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "/ABSOLUTE/PATH/TO/pag/scripts/claude-pag-hook.sh PreToolUse",
            "__pag__": true
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "/ABSOLUTE/PATH/TO/pag/scripts/claude-pag-hook.sh PostToolUse",
            "__pag__": true
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "/ABSOLUTE/PATH/TO/pag/scripts/claude-pag-hook.sh SessionStart",
            "__pag__": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "/ABSOLUTE/PATH/TO/pag/scripts/claude-pag-hook.sh Stop",
            "__pag__": true
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "/ABSOLUTE/PATH/TO/pag/scripts/claude-pag-hook.sh SubagentStop",
            "__pag__": true
          }
        ]
      }
    ]
  }
}
